# ===== apps/api =====
# Copy these into apps/api/.env
DATABASE_URL=postgresql+asyncpg://vfd:vfd@localhost:5432/vfd
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ===== apps/web =====
# Copy these into apps/web/.env.local
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
# Use API origin only (no /api or /api/v1 suffix)
NEXT_PUBLIC_API_URL=http://localhost:8000
